{
  "layer": "top",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 6,
  "position": "top",
  "margin-right": 12,
  "margin-left": 12,
  "modules-left": [
    "hyprland/workspaces",
    "sway/workspaces"
  ],
  "modules-center": [
    "custom/applauncher"
  ],
  "modules-right": [
    "network",
    "battery",
    "pulseaudio",
    "bluetooth",
    "tray",
    "custom/notifications",
    "clock"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "custom/applauncher": {
    "format": "  ",
    "on-click": "pgrep -x wofi > /dev/null && pkill -x wofi || wofi --show drun --style ~/.config/wofi/style.css --location=top -y 15",
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },

"custom/notifications": {
    "exec": "makoctl list | wc -l",
    "format": "{}",
    "interval": 2,
    "on-click": "makoctl dismiss",
    "tooltip": false,
  },

  "clock": {
    "format": " {:%H:%M}",
    "tooltip": false
  },
  "network": {
    "format-wifi": " {essid} ({signalStrength}%)",
    "format-ethernet": " {bandwidthDownBits}",
    "format-disconnected": "󰤮 No Network",
    "interval": 5,
    "on-click": "alacritty -e nmtui",
    "tooltip": false
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 100,
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "",
      "",
      " "
    ],
    "nospacing": 1,
    "format-muted": " ",
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "bluetooth": {
  "format": " {status}",
  "format-connected": " {device_alias}",
  "format-disabled": " off",
  "tooltip-format": "{controller_alias}\n\n{device_enumerate}",
  "on-click": "blueman-manager",
  "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄{capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": " {capacity}%",
    "format-icons": [
      "",
      "",
      ""
    ]
  }
}
